///
  rawPy_test.lynx — tests rawPy block/string, stdlib, built-ins.
///

void setup(){
    import("math");
    import("typing");
}

void main(){
    // rawPy block: bridge vars in and out
    print("=== rawPy block ===\n");
    int x = 0;
    rawPy(){
        x = 7 * 6
    }
    print("7*6 via rawPy = "); print(x); print("\n");

    str greeting = "";
    rawPy(){
        greeting = "Hello from Python!".upper()
    }
    print(greeting); print("\n");

    // rawPy string form
    print("=== rawPy string ===\n");
    rawPy("print('Direct Python print')");

    // built-ins
    print("=== built-ins ===\n");
    print("str_of(42) = ");    print(str_of(42));        print("\n");
    print("int_of(\"7\") = "); print(int_of("7"));       print("\n");
    print("float_of(\"1.5\") = "); print(float_of("1.5")); print("\n");

    // math stdlib
    print("=== math ===\n");
    print("abs(-9) = ");       print(global.math.abs(-9));         print("\n");
    print("max(4,7) = ");      print(global.math.max(4, 7));       print("\n");
    print("min(4,7) = ");      print(global.math.min(4, 7));       print("\n");
    print("clamp(15,0,10) = "); print(global.math.clamp(15,0,10)); print("\n");
    print("pow(2,8) = ");      print(global.math.pow(2, 8));       print("\n");
    print("sqrt(144) = ");     print(global.math.sqrt(144));       print("\n");
    print("floor(3.9) = ");    print(global.math.floor(3.9));      print("\n");
    print("ceil(3.1) = ");     print(global.math.ceil(3.1));       print("\n");

    // typing stdlib
    print("=== typing ===\n");
    print("toStr(999) = ");       print(global.typing.toStr(999));          print("\n");
    print("toInt(\"42\") = ");    print(global.typing.toInt("42"));         print("\n");
    print("isNumeric(\"3.14\") = "); print(global.typing.isNumeric("3.14")); print("\n");
    print("isNumeric(\"abc\") = "); print(global.typing.isNumeric("abc"));   print("\n");
    print("lenStr(\"hello\") = "); print(global.typing.lenStr("hello"));    print("\n");
    print("repeat(\"ab\",3) = "); print(global.typing.repeat("ab", 3));     print("\n");
    print("contains(\"foobar\",\"oba\") = "); print(global.typing.contains("foobar","oba")); print("\n");

    print("All tests passed!\n");
}
