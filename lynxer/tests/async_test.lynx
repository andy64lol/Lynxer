global setup() {}

async def slowDouble(int n) {
    await asyncSleep(0.01);
    return n * 2;
}

async global greetAsync(str name) {
    str msg = "hello " + name;
    println(msg);
}

async def test1() {
    any result = await slowDouble(7);
    return result;
}

global runTest1() {
    any got = asyncRun(test1());
    if (got is 14) {
        println("TEST 1 PASSED");
    } else {
        println("TEST 1 FAILED got=" + strOf(got));
    }
}

global runTest2() {
    asyncRun(global.greetAsync("world"));
    println("TEST 2 PASSED");
}

async def addAsync(int a, int b) {
    await asyncSleep(0.01);
    return a + b;
}

async def test3() {
    any x = await addAsync(3, 4);
    any y = await addAsync(x, 10);
    return y;
}

global runTest3() {
    any got = asyncRun(test3());
    if (got is 17) {
        println("TEST 3 PASSED");
    } else {
        println("TEST 3 FAILED got=" + strOf(got));
    }
}

async def test4() {
    any results = await asyncGather(
        slowDouble(1),
        slowDouble(2),
        slowDouble(3)
    );
    any a = listGet(results, 0);
    any b = listGet(results, 1);
    any c = listGet(results, 2);
    if (a is 2 and b is 4 and c is 6) {
        return 1;
    }
    return 0;
}

global runTest4() {
    any ok = asyncRun(test4());
    if (ok is 1) {
        println("TEST 4 PASSED");
    } else {
        println("TEST 4 FAILED");
    }
}

async def greetStr(str name) {
    await asyncSleep(0.01);
    return "hi " + name;
}

async def test5() {
    any msg = await greetStr("lynxer");
    return msg;
}

global runTest5() {
    any got = asyncRun(test5());
    if (got is "hi lynxer") {
        println("TEST 5 PASSED");
    } else {
        println("TEST 5 FAILED got=" + strOf(got));
    }
}

async def test6() {
    str caught = "";
    try {
        any x = 1 / 0;
    } catch(str err) {
        caught = err;
    }
    if (caught is "Division by zero") {
        return "ok";
    }
    return "fail";
}

global runTest6() {
    any got = asyncRun(test6());
    if (got is "ok") {
        println("TEST 6 PASSED");
    } else {
        println("TEST 6 FAILED got=" + strOf(got));
    }
}

async def test7() {
    int total = 0;
    int i = 0;
    while (i < 5) {
        total = total + i;
        i = i + 1;
    }
    return total;
}

global runTest7() {
    any got = asyncRun(test7());
    if (got is 10) {
        println("TEST 7 PASSED");
    } else {
        println("TEST 7 FAILED got=" + strOf(got));
    }
}

async global asyncMain() {
    any v = await slowDouble(21);
    if (v is 42) {
        println("TEST 8 PASSED");
    } else {
        println("TEST 8 FAILED got=" + strOf(v));
    }
}

global runTest8() {
    asyncRun(global.asyncMain());
}

global main() {
    global.runTest1();
    global.runTest2();
    global.runTest3();
    global.runTest4();
    global.runTest5();
    global.runTest6();
    global.runTest7();
    global.runTest8();
}