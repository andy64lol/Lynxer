global setup() {}

// test 1: basic async.call with return value
global runTest1() {
    async slowDouble(int n) {
        await asyncSleep(0.01);
        return n * 2;
    }
    any got = async.slowDouble(7);
    if (got is 14) {
        println("TEST 1 PASSED");
    } else {
        println("TEST 1 FAILED got=" + strOf(got));
    }
}

// test 2: async with no return value
global runTest2() {
    async greet(str name) {
        str msg = "hello " + name;
        println(msg);
    }
    async.greet("world");
    println("TEST 2 PASSED");
}

// test 3: chained async calls (sequential)
global runTest3() {
    async addAsync(int a, int b) {
        await asyncSleep(0.01);
        return a + b;
    }
    any x = async.addAsync(3, 4);
    any y = async.addAsync(x, 10);
    if (y is 17) {
        println("TEST 3 PASSED");
    } else {
        println("TEST 3 FAILED got=" + strOf(y));
    }
}

// test 4: await async.call inside another async body + asyncGather
global runTest4() {
    async slowDouble(int n) {
        await asyncSleep(0.01);
        return n * 2;
    }
    async gather3() {
        any results = await asyncGather(
            async.slowDouble(1),
            async.slowDouble(2),
            async.slowDouble(3)
        );
        return results;
    }
    any results = async.gather3();
    any a = listGet(results, 0);
    any b = listGet(results, 1);
    any c = listGet(results, 2);
    if (a is 2 and b is 4 and c is 6) {
        println("TEST 4 PASSED");
    } else {
        println("TEST 4 FAILED");
    }
}

// test 5: async returning a string
global runTest5() {
    async greetStr(str name) {
        await asyncSleep(0.01);
        return "hi " + name;
    }
    any got = async.greetStr("lynxer");
    if (got is "hi lynxer") {
        println("TEST 5 PASSED");
    } else {
        println("TEST 5 FAILED got=" + strOf(got));
    }
}

// test 6: try/catch inside async
global runTest6() {
    async risky() {
        str caught = "";
        try {
            any x = 1 / 0;
        } catch(str err) {
            caught = err;
        }
        if (caught is "Division by zero") {
            return "ok";
        }
        return "fail";
    }
    any got = async.risky();
    if (got is "ok") {
        println("TEST 6 PASSED");
    } else {
        println("TEST 6 FAILED got=" + strOf(got));
    }
}

// test 7: loop inside async
global runTest7() {
    async sumTo5() {
        int total = 0;
        int i = 0;
        while (i < 5) {
            total = total + i;
            i = i + 1;
        }
        return total;
    }
    any got = async.sumTo5();
    if (got is 10) {
        println("TEST 7 PASSED");
    } else {
        println("TEST 7 FAILED got=" + strOf(got));
    }
}

// test 8: await async.call inside async body
global runTest8() {
    async compute() {
        await asyncSleep(0.05);
        return 42;
    }
    async run() {
        int answer = await async.compute();
        return answer;
    }
    any got = async.run();
    if (got is 42) {
        println("TEST 8 PASSED");
    } else {
        println("TEST 8 FAILED got=" + strOf(got));
    }
}

// test 9: async captures outer params
global runTest9(int n) {
    async doubleN() {
        await asyncSleep(0.01);
        return n * 2;
    }
    any got = async.doubleN();
    if (got is 42) {
        println("TEST 9 PASSED");
    } else {
        println("TEST 9 FAILED got=" + strOf(got));
    }
}

global main() {
    global.runTest1();
    global.runTest2();
    global.runTest3();
    global.runTest4();
    global.runTest5();
    global.runTest6();
    global.runTest7();
    global.runTest8();
    global.runTest9(21);
}
