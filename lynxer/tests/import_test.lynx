///
  import_test.lynx — regression: import() + dot-notation module access.
  Demonstrates:
    - import("greetlib")  without .lynx extension
    - greetlib.global.GREETLIB_VERSION
    - greetlib.global.sayHi()
    - greetlib.global.sayHello(name)
///

void setup(){
    import("greetlib");
}

void main(){
    print("greetlib version: ");
    print(greetlib.global.GREETLIB_VERSION);
    print("\n");

    greetlib.global.sayHi();
    greetlib.global.sayHello("World");
}
