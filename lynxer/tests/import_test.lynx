///
  import_test.lynx — regression: import() + dot-notation module access.
  Demonstrates:
    - import("greetlib")  without .lynx extension
    - global.greetlib.GREETLIB_VERSION
    - global.greetlib.sayHi()
    - global.greetlib.sayHello(name)
///

global setup(){
    import("greetlib");
}

global main(){
    print("greetlib version: ");
    print(global.greetlib.GREETLIB_VERSION);
    print("\n");

    global.greetlib.sayHi();
    global.greetlib.sayHello("World");
}
