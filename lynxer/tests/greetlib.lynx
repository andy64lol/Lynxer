///
  greetlib.lynx — a small library for import_test.lynx
  Demonstrates: constants and functions exported via global.module.*
///

global setup(){
    const str GREETLIB_VERSION = "1.0";
}

global sayHi(){
    print("Hi from greetlib!\n");
}

global sayHello(str name){
    print("Hello, ");
    print(name);
    print("!\n");
}

global main(){}
