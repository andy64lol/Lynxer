///
  greetlib.lynx — a small library for import_test.lynx
  Demonstrates: constants and functions exported via module.global.*
///

void setup(){
    const str GREETLIB_VERSION = "1.0";
}

void sayHi(){
    print("Hi from greetlib!\n");
}

void sayHello(str name){
    print("Hello, ");
    print(name);
    print("!\n");
}

void main(){}
