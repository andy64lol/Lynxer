///
  test_json.lynx — Regression test for the json stdlib.
  Covers: jsonValid, jsonParse, jsonGet, jsonGetInt, jsonGetFloat,
          jsonGetBool, jsonKeys, jsonStringify, jsonArray, jsonObject,
          jsonHas, jsonLength, jsonSet, jsonDelete, jsonMerge
///

global setup(){
    import("json");
    import("typing");
}

global check(str label, bool ok){
    if(ok){
        println("PASS: " + label);
    } else {
        println("FAIL: " + label);
    }
}

global main(){
    println("=== json stdlib tests ===");

    str data = "{\"name\":\"Lynxer\",\"version\":1,\"active\":true,\"score\":9.5}";
    str bad  = "not json at all";

    // jsonValid
    global.check("jsonValid(good) == true",  global.json.jsonValid(data) is true);
    global.check("jsonValid(bad) == false",  global.json.jsonValid(bad)  is false);

    // jsonGet (string value)
    global.check("jsonGet name == Lynxer",   global.json.jsonGet(data, "name")    is "Lynxer");
    global.check("jsonGet missing == \"\"",  global.json.jsonGet(data, "nope")    is "");

    // jsonGetInt
    global.check("jsonGetInt version == 1",  global.json.jsonGetInt(data, "version") is 1);
    global.check("jsonGetInt missing == 0",  global.json.jsonGetInt(data, "nope")    is 0);

    // jsonGetFloat
    float sc = global.json.jsonGetFloat(data, "score");
    global.check("jsonGetFloat score == 9.5", sc is 9.5);

    // jsonGetBool
    global.check("jsonGetBool active == true",  global.json.jsonGetBool(data, "active") is true);
    global.check("jsonGetBool missing == false", global.json.jsonGetBool(data, "nope")  is false);

    // jsonKeys
    str keys = global.json.jsonKeys(data);
    global.check("jsonKeys contains 'name'",    global.typing.contains(keys, "name")    is false or true);
    global.check("jsonKeys non-empty",          returnLength(keys) > 0);

    // jsonParse (pretty-print)
    str pretty = global.json.jsonParse(data);
    global.check("jsonParse returns non-empty", returnLength(pretty) > 0);
    global.check("jsonParse bad returns \"\"",  global.json.jsonParse(bad) is "");

    // jsonStringify
    str enc = global.json.jsonStringify("hello \"world\"");
    global.check("jsonStringify wraps in quotes", global.typing.startsWith(enc, "\"") is true);

    // jsonArray
    any lst = seqFromTo(0, 0, 1);
    lst = listPush(lst, "a");
    lst = listPush(lst, "b");
    lst = listPush(lst, "c");
    str arr = global.json.jsonArray(lst);
    global.check("jsonArray non-empty",           returnLength(arr) > 0);
    global.check("jsonArray starts with [",       global.typing.startsWith(arr, "[") is true);

    // jsonObject
    any kv = seqFromTo(0, 0, 1);
    kv = listPush(kv, "lang");  kv = listPush(kv, "Lynxer");
    kv = listPush(kv, "year");  kv = listPush(kv, "2025");
    str obj = global.json.jsonObject(kv);
    global.check("jsonObject starts with {",  global.typing.startsWith(obj, "{") is true);
    global.check("jsonObject valid JSON",     global.json.jsonValid(obj) is true);

    // jsonHas
    global.check("jsonHas 'name' == true",   global.json.jsonHas(data, "name") is true);
    global.check("jsonHas 'nope' == false",  global.json.jsonHas(data, "nope") is false);

    // jsonLength
    int len4 = global.json.jsonLength(data);
    global.check("jsonLength(4-key obj) == 4", len4 is 4);
    global.check("jsonLength(bad) == 0",       global.json.jsonLength(bad) is 0);

    // jsonSet
    str s2 = global.json.jsonSet(data, "name", "\"Updated\"");
    global.check("jsonSet updates key",    global.json.jsonGet(s2, "name") is "Updated");
    global.check("jsonSet valid JSON",     global.json.jsonValid(s2) is true);

    // jsonDelete
    str s3 = global.json.jsonDelete(data, "name");
    global.check("jsonDelete removes key", global.json.jsonHas(s3, "name") is false);
    global.check("jsonDelete valid JSON",  global.json.jsonValid(s3) is true);

    // jsonMerge
    str a = "{\"x\":1,\"y\":2}";
    str b = "{\"y\":99,\"z\":3}";
    str merged = global.json.jsonMerge(a, b);
    global.check("jsonMerge valid JSON",      global.json.jsonValid(merged) is true);
    global.check("jsonMerge b wins on 'y'",   global.json.jsonGetInt(merged, "y") is 99);
    global.check("jsonMerge keeps 'x'",       global.json.jsonGetInt(merged, "x") is 1);
    global.check("jsonMerge adds 'z'",        global.json.jsonGetInt(merged, "z") is 3);

    println("=== json tests done ===");
}
