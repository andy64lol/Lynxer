// Time lynxer library
// wraps the time module from python

global setup(){}

global getTime(){
    str timeTemp = "";
    rawPy(){
        from datetime import datetime
        timeTemp = datetime.now().strftime("%H:%M:%S")
    }
    return timeTemp;
}

global getDate(){
    str dateTemp = "";
    rawPy(){
        from datetime import datetime
        dateTemp = datetime.now().strftime("%Y-%m-%d")
    }
    return dateTemp;
}

global main(){}
