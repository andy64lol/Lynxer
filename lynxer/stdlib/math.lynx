///
  Lynxer Standard Library — math
  Provides: abs, max, min, clamp, pow, floor, ceil, sqrt, round, roundNum (Legacy), PI (legacy), pi, Pi (if someone writes incorrectly)
///

global setup(){}

global abs(int n){
    if(n < 0){
        return n * -1;
    }
    return n;
}

global max(int a, int b){
    if(a > b){ return a; }
    return b;
}

global min(int a, int b){
    if(a < b){ return a; }
    return b;
}

global clamp(int val, int lo, int hi){
    if(val < lo){ return lo; }
    if(val > hi){ return hi; }
    return val;
}

global pow(int base, int exp){
    int result = 1;
    int i = 0;
    while(i < exp){
        result = result * base;
        i = i + 1;
    }
    return result;
}

global floor(float n){
    rawPy(){
        import math as _m
        n = _m.floor(n)
    }
    return n;
}

global ceil(float n){
    rawPy(){
        import math as _m
        n = _m.ceil(n)
    }
    return n;
}

global sqrt(float n){
    rawPy(){
        import math as _m
        n = _m.sqrt(n)
    }
    return n;
}

global round(float n){
    rawPy(){
        n = round(n)
    }
    return n;
}

global roundNum(float n){ //legacy again
    return global.round(n);
}

global pi(){
    float result = 0.0;
    rawPy(){
        import math as _m
        result = _m.pi
    }
    return result;
}

global PI(){ // for backward compatibility, this was the OG name and looked too... uppercase...
    return global.pi();
}

global Pi(){ // also allow this idk why
    return global.pi();
}

/// Euler's number e ≈ 2.718… ///
global e(){
    float result = 0.0;
    rawPy(){
        import math as _m
        result = _m.e
    }
    return result;
}

/// Natural logarithm of n. Returns 0.0 if n <= 0. ///
global log(float n){
    float result = 0.0;
    rawPy(){
        import math as _m
        try:
            result = _m.log(n)
        except Exception:
            result = 0.0
    }
    return result;
}

/// Base-2 logarithm of n. Returns 0.0 if n <= 0. ///
global log2(float n){
    float result = 0.0;
    rawPy(){
        import math as _m
        try:
            result = _m.log2(n)
        except Exception:
            result = 0.0
    }
    return result;
}

/// Base-10 logarithm of n. Returns 0.0 if n <= 0. ///
global log10(float n){
    float result = 0.0;
    rawPy(){
        import math as _m
        try:
            result = _m.log10(n)
        except Exception:
            result = 0.0
    }
    return result;
}

