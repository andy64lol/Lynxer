/// Convert radians to degrees. ///
global degrees(float n){
    float result = 0.0;
    rawPy(){
        import math as _m
        result = _m.degrees(n)
    }
    return result;
}

/// Convert degrees to radians. ///
global radians(float n){
    float result = 0.0;
    rawPy(){
