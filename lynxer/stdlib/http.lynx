global patch(str url, str body, str contentType){
    str result = "";
    rawPy(){
        import urllib.request as _req
        import urllib.error as _err
        try:
            _data = body.encode("utf-8")
            _rq = _req.Request(url, data=_data, method="PATCH")
            _rq.add_header("Content-Type", contentType)
            with _req.urlopen(_rq, timeout=30) as _r:
                result = _r.read().decode("utf-8", errors="replace")
        except _err.HTTPError as e:
            result = "ERROR: HTTP " + str(e.code) + " " + str(e.reason)
        except Exception as e:
            result = "ERROR: " + str(e)
    }
    return result;
}

global download(str url, str filepath){
    str result = "";
    rawPy(){
        import urllib.request as _req
        import urllib.error as _err
        try:
            _req.urlretrieve(url, filepath)
            result = "ok"
        except _err.HTTPError as e:
            result = "ERROR: HTTP " + str(e.code) + " " + str(e.reason)
        except Exception as e:
            result = "ERROR: " + str(e)
    }
    return result;
}

global urlencode(str text){
    str result = "";
    rawPy(){
        import urllib.parse as _p
        result = _p.quote_plus(text)
    }
    return result;
}

global main(){}